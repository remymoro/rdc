generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Centre {
  id         String   @id @default(uuid())
  nom        String
  ville      String
  codePostal String
  adresse    String
  telephone  String?
  email      String?
  statut     StatutCentre @default(ACTIF)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  responsables User[]
  magasins     Magasin[]

  @@unique([nom, ville, codePostal, adresse])
}

model Magasin {
  id         String       @id @default(uuid())
  nom        String
  ville      String
  codePostal String
  adresse    String
  telephone  String?
  email      String?
  statut     StatutCentre @default(ACTIF)
  centreId   String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  centre         Centre                @relation(fields: [centreId], references: [id], onDelete: Restrict)
  images         MagasinImage[]
  participations ParticipationMagasin[]
  slots          Slot[]

  @@unique([nom, ville, codePostal, adresse])
  @@index([centreId])
}

model MagasinImage {
  id        String   @id @default(uuid())
  url       String
  ordre     Int      @default(0)
  magasinId String
  createdAt DateTime @default(now())

  magasin Magasin @relation(fields: [magasinId], references: [id], onDelete: Cascade)

  @@index([magasinId])
}

model User {
  id           String                @id @default(uuid())
  email        String                @unique
  passwordHash String
  role         UserRole              @default(RESPONSABLE_CENTRE)
  centreId     String?
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  sessions     RefreshTokenSession[]
  centre       Centre?               @relation(fields: [centreId], references: [id], onDelete: SetNull)

  @@index([centreId])
}

model RefreshTokenSession {
  id          String   @id
  tokenHash   String
  userId      String
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedBy  String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Collecte {
  id            String                 @id @default(uuid())
  nom           String                 @unique
  dateDebut     DateTime
  dateFin       DateTime
  dateFinSaisie DateTime
  statut        StatutCollecte         @default(PREPARATION)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  participations ParticipationMagasin[]
  slots          Slot[]
}

model ParticipationMagasin {
  collecteId  String
  magasinId   String
  statut      StatutParticipation @default(EN_ATTENTE)

  collecte Collecte @relation(fields: [collecteId], references: [id], onDelete: Cascade)
  magasin  Magasin  @relation(fields: [magasinId], references: [id], onDelete: Cascade)

  @@id([collecteId, magasinId])
  @@index([collecteId])
}

model Produit {
  code      String   @id
  nom       String
  famille   String
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  lignes LigneSaisie[]
}

model Slot {
  id             String   @id @default(uuid())
  collecteId     String
  magasinId      String
  benevoleNom    String
  benevolePrenom String
  benevoleTel    String?
  heureDebut     DateTime
  heureFin       DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  collecte Collecte      @relation(fields: [collecteId], references: [id], onDelete: Cascade)
  magasin  Magasin       @relation(fields: [magasinId], references: [id], onDelete: Cascade)
  lignes   LigneSaisie[]

  @@index([collecteId])
  @@index([magasinId])
}

model LigneSaisie {
  slotId      String
  produitCode String
  quantite    Int

  slot    Slot    @relation(fields: [slotId], references: [id], onDelete: Cascade)
  produit Produit @relation(fields: [produitCode], references: [code])

  @@id([slotId, produitCode])
}

enum StatutCentre {
  ACTIF
  INACTIF
  ARCHIVE
}

enum StatutCollecte {
  PREPARATION
  INSCRIPTIONS_OUVERTES
  INSCRIPTIONS_FERMEES
  EN_COURS
  SAISIE_EN_COURS
  TERMINEE
}

enum StatutParticipation {
  EN_ATTENTE
  CONFIRME
  REFUSE
}

enum UserRole {
  ADMIN
  RESPONSABLE_CENTRE
}
