generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Centre {
  id         String   @id @default(uuid())
  nom        String
  ville      String
  codePostal String
  adresse    String
  telephone  String?
  email      String?
  statut     StatutCentre @default(ACTIF)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum StatutCentre {
  ACTIF
  INACTIF
  ARCHIVE
}
